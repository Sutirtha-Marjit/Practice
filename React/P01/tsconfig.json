{
    "compilerOptions": {
        "allowSyntheticDefaultImports": true,
        "jsx": "react",
        "module":"commonjs",
        "outDir": "./build/",        
        "preserveConstEnums": false,
        "removeComments": true,
        "sourceMap": true,     
        "noImplicitAny": true,   
        "target": "es5"        
    },
    "include": [
        "./src/**/*"
    ]
}